<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_hack_list.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="0dp">

    <TextView
        android:text="ROM Hack Manager"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:textSize="13sp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GBA ROMs only — tap a ROM to start the header workflow"/>

    <Button
        android:id="@+id/btn_start_bulk_queue"
        android:text="Process Queue (0)"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_hack_roms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No GBA ROMs found. Scan your SD card from the Home tab."
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

</LinearLayout>
