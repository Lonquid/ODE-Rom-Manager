<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:text="ROM Hack Manager"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:textSize="13sp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GBA ROMs where header title doesn't match filename"/>

    <TextView
        android:textSize="12sp"
        android:paddingHorizontal="16dp"
        android:paddingBottom="8dp"
        android:alpha="0.6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a ROM to review its header and assign artwork"/>

    <Button
        android:id="@+id/btn_process_all"
        android:text="Process All Unassigned"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_hack_roms"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No header mismatches found.\nAll your GBA ROMs have matching headers and filenames."
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone"/>

</LinearLayout>
